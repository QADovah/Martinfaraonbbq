---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import StatusBanner from '../components/StatusBanner.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import Nosotros from '../components/Nosotros.astro';
import Ritual from '../components/Ritual.astro';
import Menu from '../components/Menu.astro';
import Testimonios from '../components/Testimonios.astro';
import Galeria from '../components/Galeria.astro';
import Smokers from '../components/Smokers.astro';
import Faq from '../components/Faq.astro';
import Horarios from '../components/Horarios.astro';
import Contacto from '../components/Contacto.astro';
import Logia from '../components/Logia.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <!-- NAV -->
  <Header />

  <!-- STATUS BANNER -->
  <StatusBanner />

  <!-- HERO -->
  <Hero />

  <!-- MANIFESTO STRIP -->
  <Manifesto />

  <!-- HISTORIA / ABOUT -->
  <Nosotros />

  <!-- EL RITUAL -->
  <Ritual />

  <!-- MENU DE COMIDAS -->
  <Menu />

  <!-- TESTIMONIOS -->
  <Testimonios />

  <!-- GALERIA DE IMAGENES -->
  <Galeria />

  <!-- SMOKERS DE LA LOGIA -->
  <Smokers />

  <!-- PREGUNTAS FRECUENTES -->
  <Faq />

  <!-- HORARIOS E UBICACION -->
  <Horarios />

  <!-- REDES SOCIALES -->
  <Contacto />

  <!-- REGISTRO A LA LOGIA / EVENTOS -->
  <Logia />

  <!-- FOOTER & MODALS -->
  <Footer />
</Layout>

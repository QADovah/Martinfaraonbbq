---
---
<section id="smokers">
  <div class="smokers-content reveal">
    <div>
      <div class="section-label">// La maquinaria</div>
      <h2 class="section-title"><em>Smokers</em></h2>
      <p class="about-text">
        Tres ahumadores negros al fondo del local y 2 Kamados. Son el corazón del lugar. No son decoración — trabajan incluso los días que abrimos.
      </p>
      <div class="smokers-specs">
        <div class="spec-row">
          <span class="spec-key">Tipo</span>
          <span class="spec-val">Offset Smoker</span>
        </div>
        <div class="spec-row">
          <span class="spec-key">Color</span>
          <span class="spec-val red">Rojo industrial</span>
        </div>
        <div class="spec-row">
          <span class="spec-key">Combustible</span>
          <span class="spec-val">Leña dura</span>
        </div>
        <div class="spec-row">
          <span class="spec-key">Temperatura</span>
          <span class="spec-val">107–135°C</span>
        </div>
        <div class="spec-row">
          <span class="spec-key">Capacidad</span>
          <span class="spec-val">+30kg simultáneos</span>
        </div>
        <div class="spec-row">
          <span class="spec-key">Arranque</span>
          <span class="spec-key red" style="color:var(--red)">6hs antes de abrir</span>
        </div>
      </div>
    </div>

    <div class="smokers-visual" style="height:500px;border:1px solid var(--steel);overflow:hidden;position:relative;display:grid;grid-template-columns:1fr 1fr;gap:2px;background:var(--steel);">
      <img
        id="img-ahumadores"
        src="/Local/Ahumadores.webp"
        alt="Ahumadores industriales tipo Offset de Martín Faraón BBQ"
        style="width:100%;height:100%;object-fit:cover;display:block;"
        loading="lazy"
      />
      <img
        id="img-smokers"
        src="/Local/Smokers.webp"
        alt="Interior de los smokers con carne ahumándose a baja temperatura"
        style="width:100%;height:100%;object-fit:cover;display:block;"
        loading="lazy"
      />
      <div style="position:absolute;inset:0;background:linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 50%);"></div>
      <div style="position:absolute;bottom:24px;left:24px;display:flex;gap:20px;align-items:flex-end;">
        <div style="text-align:center;">
          <span style="font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--red);display:block;line-height:1;">03</span>
          <span style="font-family:'Oswald',sans-serif;font-weight:300;font-size:0.55rem;letter-spacing:3px;color:var(--silver);text-transform:uppercase;">Ahumadores XL</span>
        </div>
        <div style="text-align:center;">
          <span style="font-family:'Bebas Neue',sans-serif;font-size:2rem;color:var(--red);display:block;line-height:1;">02</span>
          <span style="font-family:'Oswald',sans-serif;font-weight:300;font-size:0.55rem;letter-spacing:3px;color:var(--silver);text-transform:uppercase;">Kamados</span>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="wood-divider"></div>

---
---
<section id="horarios">
  <div>
    <div class="section-label">// Cuándo venís</div>
    <h2 class="section-title" style="margin-bottom:40px;">Horarios</h2>

    <div class="horario-table">
      <div class="horario-header">
        <span>Días & Horarios</span>
        <span>📍 Bolívar 667</span>
      </div>
      <div class="horario-row">
        <span class="dia">Lunes</span>
        <span class="closed-tag">Cerrado</span>
      </div>
      <div class="horario-row">
        <span class="dia">Martes</span>
        <span class="closed-tag">Cerrado</span>
      </div>
      <div class="horario-row">
        <span class="dia">Miércoles</span>
        <span class="closed-tag">Cerrado</span>
      </div>
      <div class="horario-row" style="background:rgba(192,18,12,0.04)">
        <span class="dia" style="color:var(--red)">Jueves</span>
        <div class="horario-times">
          <span class="time">19:30 – 23:00</span>
        </div>
      </div>
      <div class="horario-row" style="background:rgba(192,18,12,0.04)">
        <span class="dia" style="color:var(--red)">Viernes</span>
        <div class="horario-times">
          <span class="time">19:30 – 23:00</span>
        </div>
      </div>
      <div class="horario-row" style="background:rgba(192,18,12,0.07)">
        <span class="dia" style="color:var(--red)">Sábado</span>
        <div class="horario-times">
          <span class="time">12:00 – 15:00</span>
          <span class="time-sep">· · ·</span>
          <span class="time">19:00 – 23:00</span>
        </div>
      </div>
      <div class="horario-row" style="background:rgba(192,18,12,0.07)">
        <span class="dia" style="color:var(--red)">Domingo</span>
        <div class="horario-times">
          <span class="time">12:00 – 15:00</span>
          <span class="time-sep">· · ·</span>
          <span class="time">19:00 – 23:00</span>
        </div>
      </div>
    </div>

    <p style="margin-top:16px;font-family:'Oswald',sans-serif;font-weight:300;font-size:0.65rem;letter-spacing:2px;color:var(--iron);text-transform:uppercase;">
      * Hasta agotar stock. Cuando se acaba, se acaba.
    </p>
  </div>

  <div class="location-block">
    <div class="section-label">// Dónde estamos</div>
    <h2 class="section-title" style="margin-bottom:40px;">Ubicación</h2>

    <div class="location-info">
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3281.4704044955375!2d-58.56547842345091!3d-34.668102460897044!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95bcc7ef423bc31b%3A0xe54e38e658fe8b1e!2sBol%C3%ADvar%20667%2C%20B1704%20Ramos%20Mej%C3%ADa%2C%20Provincia%20de%20Buenos%20Aires!5e0!3m2!1ses-419!2sar!4v1716300000000!5m2!1ses-419!2sar" 
        width="100%" 
        height="400" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
      <div class="location-address">Bolívar 667</div>
      <div class="location-city">Ramos Mejía · Buenos Aires · Argentina</div>
    </div>
  </div>
</section>

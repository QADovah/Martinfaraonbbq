---
<section id="menu">
  <div class="menu-header">
    <div>
      <div class="section-label">// El fuego</div>
      <h2 class="section-title">Solo<br /><em>Ahumados</em></h2>
    </div>
    <p style="font-family:'Crimson Text',serif;font-style:italic;color:var(--silver);max-width:300px;text-align:right;font-size:1rem;line-height:1.7;">
      Calidad que se huele antes de sentarse. <br /> Lo que sale de este local tardó más en cocinarse que vos en llegar.
    </p>
  </div>

  <div class="menu-filters">
    <button class="filter-btn active" data-filter="all">Todos</button>
    <button class="filter-btn" data-filter="entradas">Entradas</button>
    <button class="filter-btn" data-filter="platos">Ahumados</button>
    <button class="filter-btn" data-filter="sandwiches">Sándwiches</button>
    <button class="filter-btn" data-filter="acompanamientos">Extras</button>
    <button class="filter-btn" data-filter="especiales">Especiales</button>
  </div>

  <div id="menu-container" class="menu-grid">
    {MENU_DATA.map((item) => {
      const soldOutClass = item.status === 'sold-out' ? 'sold-out' : '';
      return (
        <div 
          class={`menu-card reveal ${soldOutClass}`} 
          style={item.style || ''} 
          data-id={item.id}
          data-category={item.category}
        >
          <div class="menu-card-image">
            <img 
              id={`img-${item.id}`} 
              src={item.img} 
              alt={item.name} 
              loading="lazy"
            />
          </div>
          <div class="menu-card-temp">
            <div class="temp-dot"></div>{item.temp}
          </div>
          <div class="menu-card-name">{item.name}</div>
          <p class="menu-card-desc">{item.desc}</p>
          {item.link ? (
            <a href={item.link} target="_blank" class="menu-card-ig-link" rel="noopener noreferrer">Ver en Instagram →</a>
          ) : (
            <span class="menu-card-tag">{item.tag}</span>
          )}
        </div>
      );
    })}
  </div>
</section>

<!-- Expose data to client side for modal and handle filter events -->
<script define:vars={{ MENU_DATA }}>
  // Save MENU_DATA globally for the modals
  window.MENU_DATA = MENU_DATA;

  document.addEventListener('DOMContentLoaded', () => {
    const filterButtons = document.querySelectorAll('.filter-btn');
    const menuCards = document.querySelectorAll('.menu-card');

    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filterValue = btn.getAttribute('data-filter');

        // Update active class
        filterButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        // Filter cards
        const container = document.getElementById('menu-container');
        if (container) {
          container.style.opacity = '0';
          setTimeout(() => {
            menuCards.forEach(card => {
              const category = card.getAttribute('data-category');
              if (filterValue === 'all' || category === filterValue) {
                card.style.display = 'flex';
              } else {
                card.style.display = 'none';
              }
            });
            container.style.opacity = '1';
          }, 200);
        }
      });
    });

    // Add click listeners to open modal
    menuCards.forEach(card => {
      card.addEventListener('click', (e) => {
        // Prevent if clicking on Instagram link
        if (e.target.classList.contains('menu-card-ig-link')) return;
        
        const itemId = card.getAttribute('data-id');
        if (window.openMenuModal && itemId) {
          window.openMenuModal(itemId);
        }
      });
    });
  });
</script>
